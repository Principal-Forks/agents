  "pv": {
    "name": "Agents Core Observability",
    "version": "1.0.0",
    "description": "Observability channels in the agents core package using Node.js diagnostics_channel",
    "markdown": ".principal-views/agents/agents.md",
    "nodeTypes": {
      "service": {
        "shape": "rectangle",
        "description": "Internal service component"
      },
      "channel": {
        "shape": "rectangle",
        "description": "Diagnostics channel for observability"
      },
      "infrastructure": {
        "shape": "hexagon",
        "description": "Infrastructure component"
      },
      "client": {
        "shape": "rectangle",
        "description": "Client-side component"
      }
    },
    "edgeTypes": {
      "emit": {
        "style": "solid",
        "color": "#3b82f6",
        "width": 2,
        "animation": {
          "type": "flow",
          "duration": 1000
        }
      },
      "collect": {
        "style": "dashed",
        "color": "#64748b",
        "width": 1
      },
      "websocket": {
        "style": "solid",
        "color": "#06b6d4",
        "width": 2,
        "animation": {
          "type": "pulse",
          "duration": 2000
        }
      }
    }
  }
